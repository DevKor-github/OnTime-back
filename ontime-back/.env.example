SPRING_APPLICATION_NAME=ontime-back

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ontime_db?useSSL=false&serverTimezone=UTC&characterEncoding=UTF-8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000
JWT_ACCESS_HEADER=Authorization
JWT_REFRESH_HEADER=Authorization-refresh

GOOGLE_WEB_CLIENT_ID=replace-me
GOOGLE_APP_CLIENT_ID=replace-me
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=replace-me

SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_ID=replace-me

APPLE_CLIENT_ID=replace-me
APPLE_TEAM_ID=replace-me
APPLE_LOGIN_KEY=replace-me
APPLE_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-adminsdk.json
FEATURE_APPLE_LOGIN_ENABLED=true
